QRM_APP_NAME="Pharma AI Risk Orchestration Backend"
QRM_APP_VERSION="0.1.0"
QRM_ENVIRONMENT="local"
QRM_DATABASE_URL="postgresql+psycopg://qrm_app:qrm_app_dev@postgres:5432/qrm_orchestration"
QRM_REDIS_URL="redis://redis:6379/0"
QRM_LOCAL_STORAGE_ROOT="./.local-storage"
QRM_PARSING_QUALITY_THRESHOLD=0.65
QRM_OOD_SCORE_THRESHOLD=0.5
QRM_SUPPORTED_DOCUMENT_LANGUAGES="en"
QRM_MINIMUM_CLAIM_COUNT=1
QRM_UNCLEAR_CLAIM_RATIO_THRESHOLD=0.4
QRM_AUDIT_LOG_ENABLED=true
QRM_ALLOW_MODEL_LIVE_INTERNET=false
QRM_API_KEYS="tenant_demo_pharma=replace-with-dev-api-key"
QRM_EXTERNAL_MODEL_CALLS_ENABLED=false
QRM_ALLOWED_MODEL_PROVIDERS="mock"
QRM_ALLOWED_NETWORK_DOMAINS=""
QRM_OPENAI_API_KEY=""
QRM_ANTHROPIC_API_KEY=""
QRM_GEMINI_API_KEY=""
QRM_OPENAI_MODEL_ID=""
QRM_ANTHROPIC_MODEL_ID=""
QRM_GEMINI_MODEL_ID=""
QRM_MODEL_PROVIDER_TIMEOUT_SECONDS=30
QRM_MODEL_PROVIDER_MAX_RETRIES=0
QRM_MODEL_PROVIDER_CIRCUIT_BREAKER_THRESHOLD=3
